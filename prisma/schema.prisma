// Prisma schema for Fölsen Honig
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum OrderStatus {
  NEU
  IN_BEARBEITUNG
  ERLEDIGT
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  products  Product[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Product {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  price       Float
  unit        String
  description String
  available   Boolean        @default(true)
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProductImage[]
  orderItems  OrderItem[]
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String   @default("")
  position  Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Order {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status     OrderStatus @default(NEU)
  note       String?
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  priceEach Float
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Einzige Zeile (Singleton, id fest "singleton") mit den redigierbaren
// Texten/Bildern der öffentlichen Seiten (Start, Über uns, Kontakt, Footer).
model SiteSettings {
  id String @id @default("singleton")

  heroEyebrow  String @default("Imkerei in Basel")
  heroTitle    String @default("Bee Swiss — naturrein, regional, mit Liebe zur Biene")
  heroSubtitle String @default("Wir sind eine kleine Imkerei in Basel und verkaufen unseren Honig sowie sanftmütige Bienenköniginnen direkt ab Hof.")
  heroImageUrl String?

  usp1Title String @default("Naturrein aus Basel")
  usp1Text  String @default("Unsere Bienenvölker stehen rund um Basel — kurze Wege, volle Frische.")
  usp2Title String @default("Handwerklich erzeugt")
  usp2Text  String @default("Kaltgeschleudert und schonend abgefüllt, ohne Zusätze.")
  usp3Title String @default("Direkt vom Imker")
  usp3Text  String @default("Kein Zwischenhandel — du kaufst direkt bei uns, mit Herz für die Biene.")

  ctaTitle String @default("Fragen zu Honig oder Bienenköniginnen?")
  ctaText  String @default("Melde dich gerne über unser Kontaktformular — wir antworten schnellstmöglich.")

  aboutTitle    String  @default("Unsere Imkerei in Basel")
  aboutText     String  @default("Bee Swiss ist eine kleine, familiengeführte Imkerei in Basel. Was als Hobby mit wenigen Völkern begann, ist heute eine Leidenschaft, die wir mit Sorgfalt und Respekt vor der Natur betreiben.\n\nUnsere Bienenvölker stehen an sonnigen, blütenreichen Standorten rund um Basel. Wir schleudern unseren Honig kalt und schonend, füllen ihn direkt ab und verzichten bewusst auf jegliche Zusätze — so bleibt der volle, natürliche Geschmack erhalten.\n\nNeben Honig züchten wir auch eigene Bienenköniginnen. Uns ist wichtig, dass unsere Völker sanftmütig, gesund und widerstandsfähig sind — Eigenschaften, die wir bei der Zucht gezielt fördern.\n\nWir freuen uns, wenn du unsere Produkte probierst — direkt ab Hof, im Onlineshop oder auf Anfrage.")
  aboutImageUrl String?

  contactIntro   String @default("Fragen zu Honig, Bienenköniginnen oder einer grösseren Bestellung? Wir freuen uns von dir zu hören.")
  contactEmail   String @default("info@bee-swiss.ch")
  contactAddress String @default("Basel, Schweiz")
  openingHours   String @default("Hofladen: Samstag 09:00–12:00 Uhr, oder nach Vereinbarung")

  footerTagline String @default("Naturreiner Honig und Bienenköniginnen direkt vom Imker aus Basel — handwerklich erzeugt, mit Liebe zur Biene.")

  updatedAt DateTime @updatedAt
}
