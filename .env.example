# Kopiere diese Datei zu ".env" und trage echte Werte ein.
# Diese Beispieldatei enthält keine echten Geheimnisse und darf committed werden.

DATABASE_URL="file:./dev.db"

# Ordner für hochgeladene Produktbilder. Optional - ohne diese Variable wird
# lokal automatisch ein "uploads"-Ordner im Projektverzeichnis verwendet.
# In Produktion auf einen persistenten Speicherort setzen, z.B. "/data/uploads".
# UPLOAD_DIR="./uploads"

# Zufälligen Wert generieren, z.B. mit: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-value"

# Initialer Admin-Zugang, wird beim Seed-Skript angelegt
ADMIN_EMAIL="info@bee-swiss.ch"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Admin"

# Mailversand für Kontaktformular & Bestellanfragen (SMTP über Gmail).
# SMTP_PASSWORD muss ein Gmail-"App-Passwort" sein (nicht das normale Gmail-Passwort) -
# siehe README für die Anleitung. Ohne SMTP_PASSWORD wird nur in der Datenbank
# gespeichert (im Admin-Bereich sichtbar) und keine Mail verschickt.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Bee Swiss <deine-adresse@gmail.com>"
CONTACT_NOTIFICATION_EMAIL=""
